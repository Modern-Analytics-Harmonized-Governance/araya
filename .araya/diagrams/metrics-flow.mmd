flowchart LR
    subgraph Coverage
        RC[Req Coverage]
        AC[AC Coverage]
        TC[Task Coverage]
    end
    
    subgraph Lifecycle
        DR[Draft]
        PL[Planned]
        AP[Approved]
        EX[Executing]
        RV[Review]
        VD[Validated]
        AR[Archived]
    end
    
    subgraph Validation
        PA[Passed ACs]
        FA[Failed ACs]
        PE[Pending ACs]
    end
    
    Coverage --> HS{Health Score}
    Lifecycle --> HS
    Validation --> HS
    
    HS -->|≥ 95| GN[🟢 GREEN]
    HS -->|80-94| YW[🟡 YELLOW]
    HS -->|< 80| RD[🔴 RED]
    
    style GN fill:#9f9,stroke:#333
    style YW fill:#ff9,stroke:#333
    style RD fill:#f99,stroke:#333
    style HS fill:#fff,stroke:#333,stroke-width:2px
